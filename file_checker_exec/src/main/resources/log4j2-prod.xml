<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn">

  <Properties>
    <Property name="logfile">${__sys__:logfile.name:-FileChecker_all_LOG}</Property>
    <Property name="suffix">${__sys__:log_suffix:-}</Property>
  </Properties>

  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n" />
    </Console>

    <RollingFile name="File" 
                 fileName="${logfile}${suffix}.log" 
                 filePattern="${logfile}${suffix}-%i.log"
                 createOnDemand="true"
                 immediateFlush="true" 
                 append="true">
      <PatternLayout pattern="%d{yyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} - %msg%n"/>
      <Policies>
        <SizeBasedTriggeringPolicy size="1 MB"/>
      </Policies>
      <DefaultRolloverStrategy max="1"/>
    </RollingFile>
  </Appenders>

  <Loggers>
   <Logger name="ArgoFileSpecification" level="warn" additivity="false">
   		<AppenderRef ref="Console"/>
      	<AppenderRef ref="File" level="off"/>
   </Logger>
   <Logger name="ValidateSubmit" level="warn" additivity="false">
   		<AppenderRef ref="Console"/>
      	<AppenderRef ref="File" level="off"/>
   </Logger>
    <Root level="off" />
	

  </Loggers>
</Configuration>
